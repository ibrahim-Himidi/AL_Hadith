# === MySQL ===
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=hadis_db
MYSQL_USER=hadis_user
MYSQL_PASSWORD=hadis_pass
MYSQL_ROOT_PASSWORD=rootpass

# Async MySQL bağlantı URL'si (SQLAlchemy + asyncmy)
DATABASE_URL=mysql+asyncmy://hadis_user:hadis_pass@db:3306/hadis_db?charset=utf8mb4

# === Qdrant ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_AR=hadisler_ar
QDRANT_COLLECTION_EN=hadisler_en

# === JWT Auth ===
SECRET_KEY=BURAYA_GUCLU_BIR_ANAHTAR_YAZ_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# === NLP Model ===
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768

# === API ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true
